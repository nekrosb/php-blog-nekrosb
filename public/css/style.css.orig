:root {
    --primary-color: #2563eb;
    --primary-hover: #1d4ed8;
    --bg-color: #f3f4f6;
    --card-bg: #ffffff;
    --text-main: #1f2937;
    --text-muted: #6b7280;
    --border-color: #e5e7eb;
    --accent-color: #10b981;
    --accent-hover: #059669;
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    --radius-md: 0.5rem;
    --radius-lg: 0.75rem;
    --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}

body {
    font-family: var(--font-sans);
    background-color: var(--bg-color);
    color: var(--text-main);
    margin: 0;
    padding: 0;
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

h1, h2, h3, h4 {
    color: var(--text-main);
    margin-top: 0;
    font-weight: 700;
}

a {
    color: var(--primary-color);
    text-decoration: none;
    transition: color 0.2s ease;
}

a:hover {
    color: var(--primary-hover);
    text-decoration: underline;
}

/* ===== HEADER ===== */
header {
    background-color: var(--card-bg);
    border-bottom: 1px solid var(--border-color);
    padding: 1rem 2rem;
    display: flex;
    justify-content: center;
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 0;
    z-index: 50;
}

header nav {
    width: 100%;
    max-width: 1000px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

header h1 {
    margin: 0;
    font-size: 1.5rem;
    color: var(--primary-color);
}

nav ul {
    display: flex;
    gap: 1.25rem;
    margin: 0;
    padding: 0;
    align-items: center;
    list-style: none;
}

body > nav > ul {
    justify-content: center;
    margin: 2rem 0;
}

body > nav > ul li a,
body > nav > ul li strong {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-md);
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    color: var(--text-main);
    font-weight: 500;
    text-decoration: none;
}

body > nav > ul li strong {
    background: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
}

body > nav > ul li a:hover {
    background: var(--bg-color);
    text-decoration: none;
}

/* ===== BUTTONS ===== */
button,
a.login,
a.register,
form > button[type="submit"],
.post form > button {
    display: inline-block;
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 0.5rem 1rem;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-main);
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: all 0.2s ease;
    text-align: center;
    text-decoration: none;
}

button:hover,
a.login:hover,
a.register:hover,
form > button[type="submit"]:hover,
.post form > button:hover {
    background-color: var(--bg-color);
    border-color: #d1d5db;
    text-decoration: none;
}

button:active,
a.login:active,
a.register:active {
    transform: translateY(1px);
    box-shadow: none;
}

form > button[type="submit"],
a.register {
    background-color: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
}

form > button[type="submit"]:hover,
a.register:hover {
    background-color: var(--primary-hover);
    color: white;
    border-color: var(--primary-hover);
}

header form {
    margin: 0;
}

/* ===== CREATE POST BUTTON ===== */
.btn-create-post {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    font-size: 1.5rem;
    font-weight: 400;
    background-color: var(--accent-color);
    color: white;
    border: none;
    box-shadow: var(--shadow-sm);
    transition: all 0.2s ease;
    line-height: 1;
    text-decoration: none !important;
}

.btn-create-post:hover {
    background-color: var(--accent-hover);
    transform: scale(1.05);
    color: white !important;
}

/* ===== LAYOUT & CONTAINERS ===== */
.post-container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
    flex-grow: 1;
}

.profile-container {
    width: 100%;
    max-width: 800px;
    margin: 2rem auto;
    padding: 1.5rem;
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-color);
}

/* ===== POST ===== */
.post {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.post:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
}

.post h1, .post h2 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--text-main);
    line-height: 1.3;
}

.post > p, .post > strong {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0;
    margin-bottom: 0.5rem;
    display: block;
}

.post hr {
    border: 0;
    border-top: 1px solid var(--border-color);
    margin: 1rem 0;
}

.post img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: 1rem 0;
    border: 1px solid var(--border-color);
    display: block;
}

.content {
    margin: 1rem 0;
    color: #374151;
    font-size: 1rem;
    line-height: 1.6;
    padding: 0;
    transition: height 0.35s ease;
}

/* Clamp content only if it has a toggle button in the DOM near it */
.content:has(+ .toggle-btn) {
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
}

.content.open {
    -webkit-line-clamp: unset !important;
    line-clamp: unset !important;
}

.toggle-btn {
    background: transparent;
    border: none;
    box-shadow: none;
    color: var(--primary-color);
    padding: 0;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 1rem;
    text-transform: lowercase;
}

.toggle-btn:hover {
    background: transparent;
    border: none;
    color: var(--primary-hover);
    text-decoration: underline;
}

.post form {
    display: inline-block;
    margin-right: 0.5rem;
}

/* ===== MENU WINDOW (Forms/Auth/Edit) ===== */
.menu-container {
    width: 100%;
    max-width: 450px;
    margin: 3rem auto;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-md);
}

form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

label {
    font-weight: 600;
    color: var(--text-main);
    font-size: 0.95rem;
    margin-bottom: -0.5rem;
}

input[type="text"],
input[type="email"],
input[type="password"],
textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    font-size: 1rem;
    background-color: #f9fafb;
    font-family: var(--font-sans);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
}

textarea {
    min-height: 150px;
    resize: vertical;
}

input[type="file"] {
    padding: 0.5rem 0;
    font-size: 0.95rem;
    color: var(--text-muted);
}

input:focus,
textarea:focus {
    outline: none;
    border-color: var(--primary-color);
    background-color: white;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
}

button[type="reset"] {
    background-color: transparent;
    color: var(--text-muted);
    border: 1px solid transparent;
    box-shadow: none;
}

button[type="reset"]:hover {
    background-color: var(--bg-color);
    color: var(--text-main);
    border: 1px solid var(--border-color);
}

/* ===== COMMENTS SECTION ===== */
.comments-section {
    margin-top: 3rem;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
}

.comments-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
}

.comment {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    margin-bottom: 1rem;
    box-shadow: var(--shadow-sm);
}

.comment strong {
    color: var(--text-main);
    font-size: 1.05rem;
    display: block;
}

.comment p {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin: 0.25rem 0 0.75rem 0;
}

.post-container > form {
    margin-top: 2rem;
    background: var(--card-bg);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-sm);
}

/* ===== FOOTER ===== */
footer {
    margin-top: auto;
    background-color: #1f2937;
    color: #9ca3af;
    text-align: center;
    padding: 1.5rem;
    font-size: 0.9rem;
}

/* ===== MOBILE ===== */
@media (max-width: 640px) {
    header {
        padding: 1rem;
    }

    header nav {
        flex-direction: column;
        gap: 1rem;
    }

    nav ul {
        flex-wrap: wrap;
        justify-content: center;
    }

    .post-container, .profile-container, .menu-container {
        padding: 1.5rem 1rem;
        border-radius: 0;
        border-left: none;
        border-right: none;
        margin-top: 0;
    }

    .post {
        padding: 1.25rem;
    }
}
